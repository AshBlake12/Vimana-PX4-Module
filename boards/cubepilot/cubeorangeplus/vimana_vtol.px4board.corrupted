CONFIG_MODULES_VIMANA=y

# Disabled unused airframes
CONFIG_MODULES_AIRSHIP_ATT_CONTROL=n
CONFIG_MODULES_ROVER_POS_CONTROL=n
CONFIG_MODULES_UUV_ATT_CONTROL=n

# Disabled simulation
CONFIG_MODULES_SIMULATOR_SIH=n

# Disabled unused sensors
CONFIG_DRIVERS_OPTICAL_FLOW=n
CONFIG_DRIVERS_DISTANCE_SENSOR=n

# Disabled gimbal/camera (to be added later)
CONFIG_MODULES_GIMBAL=n
CONFIG_MODULES_CAMERA_FEEDBACK=n

# Disable debug tools
CONFIG_SYSTEMCMDS_SERIAL_TEST=n
CONFIG_SYSTEMCMDS_DUMPFILE=n

# Found out which were consuming most flash
# Used the commands -> for dir in build/cubepilot_cubeorangeplus_vimana_vtol/src/modules/*; do
# du -sh $dir 2>/dev/null
# done | sort -rh | head -10

# arm-none-eabi-size -A build/cubepilot_cubeorangeplus_vimana_vtol/*.elf | head -20



# ROS2/DDS - (Will use when companion comp is back)
CONFIG_MODULES_UXRCE_DDS_CLIENT=n

# Autotune
CONFIG_MODULES_FW_AUTOTUNE_ATTITUDE_CONTROL=n
CONFIG_MODULES_MC_AUTOTUNE_ATTITUDE_CONTROL=n

# Septentrio GPS  (we had holybro)
# Sagetech ADS-B transponder - not needed
CONFIG_DRIVERS_TRANSPONDER_SAGETECH_MXS=n

# Smart battery stuff
CONFIG_DRIVERS_BATT_SMBUS=n
CONFIG_MODULES_ESC_BATTERY=n
CONFIG_DRIVERS_SMART_BATTERY_BATMON=n

# ADIS16448 IMU - (not on Cube!!)
CONFIG_DRIVERS_IMU_ANALOG_DEVICES_ADIS16448=n

# ICM20649 - (not on Cube!!)
CONFIG_DRIVERS_IMU_INVENSENSE_ICM20649=n

# ICM45686 - (not on Cube!!)
CONFIG_DRIVERS_IMU_INVENSENSE_ICM45686=n

# ADS1115 ADC - (not on Cube!!)
CONFIG_DRIVERS_ADC_ADS1115=n

# IRLock
CONFIG_DRIVERS_IRLOCK=n

# Camera - (adding later)
CONFIG_DRIVERS_CAMERA_CAPTURE=n
CONFIG_DRIVERS_CAMERA_TRIGGER=n
CONFIG_MODULES_CAMERA_FEEDBACK=n

# Gimbal - (adding later)
CONFIG_MODULES_GIMBAL=n

# Landing target
CONFIG_MODULES_LANDING_TARGET_ESTIMATOR=n

# Optical flow
CONFIG_COMMON_OPTICAL_FLOW=y

# PCA9685 PWM (not using)
CONFIG_DRIVERS_PCA9685_PWM_OUT=n

# PWM input
CONFIG_DRIVERS_PWM_INPUT=n

# FW lateral/longitudinal, tailsitter uses different controller
CONFIG_MODULES_FW_LATERAL_LONGITUDINAL_CONTROL=n
CONFIG_MODULES_FW_MODE_MANAGER=n

# Gyro calibration module (apparantly the sensor module handles this)
CONFIG_MODULES_GYRO_CALIBRATION=n

# Mag bias estimator
CONFIG_MODULES_MAG_BIAS_ESTIMATOR=n

# Load monitor
CONFIG_MODULES_LOAD_MON=n

# Some debug system commands
CONFIG_SYSTEMCMDS_GPIO=n
CONFIG_SYSTEMCMDS_BSONDUMP=n
CONFIG_SYSTEMCMDS_TOPIC_LISTENER=n
CONFIG_SYSTEMCMDS_WORK_QUEUE=n
CONFIG_SYSTEMCMDS_ACTUATOR_TEST=n
